{
  "name": "@marwansaab/obsidian-cli-mcp",
  "version": "0.2.0",
  "description": "Windows-host MCP server bridging MCP clients to the Obsidian Integrated CLI binary. Ships obsidian_exec (generic CLI bridge), help (progressive-disclosure docs), and read_note (typed read tool).",
  "type": "module",
  "bin": {
    "obsidian-cli-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs/tools/**/*.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.3.0",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
