{
  "name": "@marwansaab/obsidian-cli-mcp",
  "version": "0.8.0",
  "description": "Cross-platform MCP server bridging MCP clients to the Obsidian Integrated CLI binary on macOS, Linux, and Windows hosts. Typed tools: append_note, backlinks, context_search, delete, files, find_and_replace, find_by_property, links, move, obsidian_exec, outline, patch_block, patch_heading, paths, pattern_search, prepend, properties, query_base, read, read_heading, read_property, rename, search, set_property, smart_connections_query, smart_connections_similar, tag, write_note + help.",
  "type": "module",
  "bin": {
    "obsidian-cli-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs/tools/**/*.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "baseline:write": "node scripts/write-register-baseline.ts",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.3.0",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
